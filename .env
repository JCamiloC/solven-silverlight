# =========================================
# CONFIGURACIÓN DE AMBIENTE
# =========================================

# Ambiente actual (development | staging | production)
NODE_ENV=development

# URL base de la aplicación
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nombre del cliente para personalización
NEXT_PUBLIC_CLIENT_NAME="Silverlight Colombia"

# Tema corporativo por defecto
NEXT_PUBLIC_DEFAULT_THEME=silverlight

# =========================================
# CONFIGURACIÓN DE CORREO
# =========================================
# Para envío de invitaciones y notificaciones

# Configuración SMTP (opcional - usar Supabase Auth por defecto)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=notificaciones@silverlight.com.co
# SMTP_PASSWORD=your_app_password
# SMTP_FROM="Solven - Silverlight Colombia <notificaciones@silverlight.com.co>"

# =========================================
# CONFIGURACIÓN DE SEGURIDAD
# =========================================

# Secret para JWT y sesiones (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET=your-super-secret-jwt-key-here

# URL para callbacks de autenticación
NEXTAUTH_URL=http://localhost:3000

# =========================================
# CONFIGURACIÓN DE ALMACENAMIENTO
# =========================================

# Bucket de Supabase para archivos
NEXT_PUBLIC_STORAGE_BUCKET=solven-files

# Límite de tamaño de archivos (en MB)
NEXT_PUBLIC_MAX_FILE_SIZE=10

# =========================================
# CONFIGURACIÓN DE API EXTERNA
# =========================================
# Para integraciones futuras

# API Key para servicios externos (si se requiere)
# EXTERNAL_API_KEY=your-external-api-key
# EXTERNAL_API_URL=https://api.external-service.com

# =========================================
# OPENAI + CHAT SOPORTE
# =========================================

# API Key de OpenAI (solo servidor, NO usar NEXT_PUBLIC)
OPENAI_API_KEY=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

# Modelo a usar en el asistente
OPENAI_MODEL=gpt-4.1-mini

# Canales oficiales de soporte que el chat debe compartir (sin inventar)
SUPPORT_CONTACT_PHONE=313 4496406
SUPPORT_CONTACT_EMAIL=soporte@silverlight.com.co
SUPPORT_CONTACT_WHATSAPP=313 4496406

# Realtime de Supabase para chat: true = realtime, false = polling
NEXT_PUBLIC_CHAT_REALTIME_ENABLED=false

# Mostrar React Query Devtools solo cuando sea necesario
NEXT_PUBLIC_SHOW_REACT_QUERY_DEVTOOLS=false

# =========================================
# CONFIGURACIÓN DE LOGS Y MONITOREO
# =========================================

# Nivel de logs (error | warn | info | debug)
LOG_LEVEL=info

# Habilitar logs de base de datos en desarrollo
DATABASE_DEBUG=false

# =========================================
# CONFIGURACIÓN ESPECÍFICA DE SILVERLIGHT
# =========================================

# Prefijo para tablas de BD (para multi-tenant futuro)
DB_TABLE_PREFIX=silverlight_

# Zona horaria del cliente
TIMEZONE=America/Bogota

# Configuración regional
LOCALE=es-CO
CURRENCY=COP

# =========================================
# INSTRUCCIONES DE CONFIGURACIÓN
# =========================================

# 1. Crear proyecto en Supabase:
#    - Ir a https://supabase.com/dashboard
#    - Crear nuevo proyecto: "solven-silverlight"
#    - Región: South America (São Paulo) para mejor latencia
#    - Plan: Pro (recomendado para producción)

# 2. Ejecutar migraciones de base de datos:
#    - Ejecutar scripts en /database/ en orden
#    - Configurar RLS (Row Level Security)
#    - Crear usuarios iniciales

# 3. Configurar Storage:
#    - Crear bucket "solven-files"
#    - Configurar políticas de acceso
#    - Establecer límites de tamaño

# 4. Configurar Auth:
#    - Habilitar registro por email
#    - Configurar plantillas de email
#    - Establecer políticas de contraseñas

# 5. Variables de producción:
#    - Nunca exponer SUPABASE_SERVICE_ROLE_KEY
#    - Usar variables de entorno del servidor
#    - Configurar dominio personalizado
#    - Habilitar SSL/HTTPS

